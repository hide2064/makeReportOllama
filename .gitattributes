# デフォルト: テキストファイルは LF で管理
* text=auto

# Windows バッチファイルは必ず CRLF（cmd.exe がラベルに CRLF を必要とするため）
*.bat text eol=crlf
*.cmd text eol=crlf

# Python / JS / CSS / HTML は LF
*.py  text eol=lf
*.ts  text eol=lf
*.tsx text eol=lf
*.js  text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md  text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# バイナリ
*.pptx binary
*.xlsx binary
*.png  binary
*.jpg  binary
*.pdf  binary
